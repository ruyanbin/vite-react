{
  "name": "vite-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --fix",
    "lint:check": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "prettier": "prettier --write ./",
    "prettier:check": "prettier --check ./",
    "preview": "vite preview",
    "prepare": "husky install",
    "commit": "git add . && git cz"
  },
  "dependencies": {
    "@iconify/json": "^2.2.447",
    "@iconify/react": "^6.0.2",
    "@iconify/tailwind": "^1.2.0",
    "ahooks": "^3.9.6",
    "antd": "^6.3.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "iconify-icon": "^1.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "sass": "^1.97.3",
    "vite-plugin-legacy": "^2.1.0",
    "vite-plugin-mock": "^3.0.2",
    "zustand": "^5.0.11"
  },
  "lint-staged": {
    "*.{ts,tsx,vue,jsx}": [
      "npm run lint",
      "npm run prettier"
    ],
    "src/**/*.{vue,less,postcss,css,scss}": [
      "stylelint --max-warnings 0"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@iconify-json/ant-design": "^1.2.5",
    "@tailwindcss/vite": "^4.2.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "autoprefixer": "^10.4.27",
    "commitizen": "^4.3.1",
    "commitlint": "^20.4.3",
    "commitlint-config-cz": "^0.13.3",
    "cz-conventional-changelog": "^3.3.0",
    "cz-customizable": "^7.5.1",
    "eslint": "^8.57.0",
    "eslint-config-mature": "^0.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "i": "^0.3.7",
    "lint-staged": "^16.3.2",
    "mockjs": "^1.1.0",
    "npm": "^11.11.0",
    "postcss": "^8.5.8",
    "postcss-px-to-viewport": "^1.1.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "rollup-plugin-external-globals": "^0.13.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "rxjs": "^7.8.2",
    "scss": "^0.2.4",
    "scss-loader": "^0.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^7.3.1",
    "vite-plugin-compression2": "^2.5.0",
    "vitest": "^3.1.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-customizable"
    },
    "cz-customizable": {
      "config": ".cz-config.cjs"
    }
  }
}
